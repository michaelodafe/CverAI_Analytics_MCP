# ── DeepSeek ────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── Database ─────────────────────────────────────────────────────────────────
# Direct connection:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
#
# Via SSH tunnel (tunnel on host port 5433, Docker accesses via host.docker.internal):
DATABASE_URL=postgresql://user:password%40host:5433/dbname

# ── Bridge tuning ────────────────────────────────────────────────────────────
MAX_TOKENS=8192
MAX_ITERATIONS=15
